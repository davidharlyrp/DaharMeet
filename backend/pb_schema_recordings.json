{
    "id": "recordings",
    "name": "recordings",
    "type": "base",
    "schema": [
        {
            "name": "meeting_id",
            "type": "text",
            "required": true
        },
        {
            "name": "user_name",
            "type": "text",
            "required": true
        },
        {
            "name": "duration",
            "type": "number",
            "required": false
        },
        {
            "name": "status",
            "type": "select",
            "required": true,
            "options": {
                "values": [
                    "uploading",
                    "completed",
                    "failed"
                ]
            }
        },
        {
            "name": "raw_file",
            "type": "file",
            "required": false,
            "options": {
                "maxSelect": 1,
                "maxSize": 524288000
            }
        },
        {
            "name": "recorded_at",
            "type": "date",
            "required": true
        }
    ]
}